# =============================================================================
# Project ATLAS — Frontend Environment Variables
# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL of the ATLAS backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API version prefix
NEXT_PUBLIC_API_VERSION=v1

# ---------------------------------------------------------------------------
# Authentication (IP-002 — Identity & Access)
# ---------------------------------------------------------------------------

# OAuth2 / OIDC provider issuer URL
NEXT_PUBLIC_AUTH_ISSUER=http://localhost:8080/realms/atlas

# OAuth2 client ID (public client, safe to expose)
NEXT_PUBLIC_AUTH_CLIENT_ID=atlas-web

# Auth redirect URI after login
NEXT_PUBLIC_AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Post-logout redirect URI
NEXT_PUBLIC_AUTH_POST_LOGOUT_URI=http://localhost:3000

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------

# Enable React Query devtools in production (default: false)
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=false

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Application name sent in X-Request-ID / correlation headers
NEXT_PUBLIC_APP_NAME=atlas-frontend

# Environment label (development | staging | production)
NEXT_PUBLIC_ENVIRONMENT=development

# Minimum log level for the frontend logging foundation (debug | info | warn | error)
NEXT_PUBLIC_LOG_LEVEL=debug
