# ============================================================
# Project ATLAS — EditorConfig
# Governed by: IP-001 §15 (UTF-8 encoding standard),
# ES-001 (consistent coding standards)
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python (backend — IP-001)
[*.py]
indent_size = 4

# Web / config formats (frontend — IP-001)
[*.{js,jsx,ts,tsx,json,css,scss,html}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# Markdown (trailing spaces are significant line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab

# Windows scripts
[*.{cmd,bat,ps1}]
end_of_line = crlf
